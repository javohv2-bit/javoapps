  "productInfo": {
    "name": "EOS R3 (Body)",
    "tagline": "",
    "description": "",
    "specs": {},
    "sections": [
      {
        "title": "Promotion",
        "description": "The pride of the full-frame mirrorless series, the Canon EOS R3 is expertly designed for advanced amateurs and pros. It features new, state-of-the-art imaging technologies to give you top-tier performance in speed, sensitivity, and reliability for a fast-paced environment."
      },
      {
        "title": "Promotion",
        "description": ""
      },
      {
        "title": "Promotion",
        "description": ""
      },
      {
        "title": "Key Features",
        "description": ""
      },
      {
        "title": "Superior Image Quality",
        "description": "Capture your world with all the crisp details. The EOS R3 is equipped with a new approximately 24.1-megapixel back-illuminated stacked CMOS sensor combined with DIGIC X image processor for the first time, allowing for high-speed readout and high image quality with low noise."
      },
      {
        "title": "High Speed, High Precision",
        "description": "Capture explosive action in a blink of an eye."
      },
      {
        "title": "",
        "description": "Perform high-speed continuous shooting at up to 30 fps with the electronic shutter (or up to 12 fps with mechanical shutter)."
      },
      {
        "title": "Intelligent Tracking and Recognition",
        "description": "A camera that sees and understands your world. With a new, evolved EOS iTR (Intelligent Tracking & Recognition) AF X using deep learning technology, subject detection of the EOS R3 is faster and smarter than ever."
      },
      {
        "title": "Enhanced Eye Detection AF Performance",
        "description": "Subject detection precision has also been enhanced for humans."
      },
      {
        "title": "Seamless Moviemaking Magic",
        "description": "Lights, camera, ready for action."
      },
      {
        "title": "6K 60p RAW",
        "description": "Record in-camera 6K 60p RAW video footage for greater versatility in post-production. The rich 12-bit image data produces richer colours while the high pixel count (6000 x 3164) offers flexibility in cropping and angle correction."
      },
      {
        "title": "HDR PQ Movies",
        "description": "Record 4:2:2 10-bit HDR PQ movies with higher brightness, wider tonal range and wider colour gamut for playback on HDR-compatible screens."
      },
      {
        "title": "Connection At Your Fingertips",
        "description": "Get your images and videos to the rest of the world in quick time. With the myriad of connectivity options available on the EOS R3, expect greater convenience and more efficient workflows for casual and professional users alike."
      },
      {
        "title": "Built-in Wi-Fi",
        "description": "Transfer files wirelessly and quickly from the EOS R3 to your smart device, PC or FTP server using high-speed 5GHz built-in Wi-Fi*. The EOS R3 supports Wi-Fi Protected Access 3 (WPA3) for added file security on wireless networks."
      },
      {
        "title": "Built For Strength",
        "description": "❖"
      },
      {
        "title": "Silent, Durable Shutter",
        "description": "For high-speed burst shooting performance, the EOS R3 is equipped with a highly durable shutter capable of shooting up to 500,000 cycles."
      },
      {
        "title": "New Multi-Function Shoe",
        "description": "Sporting a next-generation interface with dust- and water-resistant design, the brand-new Multi-Function Shoe supports various types of accessories by using power supply from the camera."
      },
      {
        "title": "For Flash Photography",
        "description": "Enjoy the convenience and ease of wireless flash photography and a cleaner setup with this radio-enabled and battery-less Speedlite transmitter that can remotely control multiple Speedlite units."
      },
      {
        "title": "Video Gallery",
        "description": ""
      },
      {
        "title": "Shot on EOS R3",
